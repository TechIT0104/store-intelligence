# Copy to .env and fill in. .env is gitignored.

# --- API / services (defaults match docker-compose) ---
DATABASE_URL=postgresql+psycopg://storeiq:storeiq@localhost:5432/storeiq
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO

# --- Detection pipeline (host) ---
STORE_LAYOUT_PATH=./data/store_layout.json
POS_CSV_PATH=./data/pos_transactions.csv
CLIPS_DIR=../CCTV Footage-20260529T160731Z-3-00144614ea/CCTV Footage
EVENTS_OUT=./pipeline/output/events.jsonl
YOLO_MODEL=yolov8n.pt
SAMPLE_FPS=5            # process N frames/sec (source is 25-30fps)
DEVICE=0               # GPU id, or "cpu"

# --- Optional VLM (staff + zone validation). Leave blank to use heuristics only. ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
VLM_MODEL=gemini-2.5-flash
